generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  SOLO
  STUDIO
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum DiscountType {
  FULL_ACCESS
  PERCENTAGE
}

enum LegacyMemberRole {
  OWNER
  MEMBER
}

enum Permission {
  VIEW_LEADS
  MANAGE_LEADS
  VIEW_CLIENTS
  MANAGE_CLIENTS
  VIEW_PROJECTS
  MANAGE_PROJECTS
  VIEW_TASKS
  MANAGE_TASKS
  VIEW_INBOX
  SEND_MESSAGES
  VIEW_PROPOSALS
  MANAGE_PROPOSALS
  SEND_PROPOSALS
  VIEW_CONTRACTS
  MANAGE_CONTRACTS
  SEND_CONTRACTS
  VIEW_INVOICES
  MANAGE_INVOICES
  SEND_INVOICES
  RECORD_PAYMENTS
  VIEW_REPORTS
  VIEW_CALENDAR
  MANAGE_CALENDAR
  VIEW_FORMS
  MANAGE_FORMS
  VIEW_AUTOMATIONS
  MANAGE_AUTOMATIONS
  MANAGE_WORKSPACE_SETTINGS
  MANAGE_BILLING
  MANAGE_MEMBERS
  MANAGE_INTEGRATIONS
}

model Workspace {
  id                String   @id
  name              String
  logoUrl           String?
  businessName      String?
  gstNumber         String?
  panNumber         String?
  businessType      String?
  razorpayAccountId String?
  razorpayKeyId     String?
  razorpayKeySecret String?
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  upiId             String?
  upiQrUrl          String?
  country           String?
  currency          String?
  taxLabel          String?
  ibanNumber        String?
  swiftCode         String?
  routingNumber     String?
  defaultHsnSac     String?
  defaultLutNumber  String?
  emailSignature    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  members     WorkspaceMember[]
  activeUsers User[]           @relation("ActiveWorkspace")

  leads               Lead[]
  clients             Client[]
  proposals           Proposal[]
  contracts           Contract[]
  invoices            Invoice[]
  automationRules     AutomationRule[]
  automationWorkflows AutomationWorkflow[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  meetings            Meeting[]
  proposalTemplates   ProposalTemplate[]
  promoRedemptions    PromoRedemption[]
  intakeForms         IntakeForm[]
  timeEntries         TimeEntry[]
  expenses            Expense[]
  expenseCategories   UserExpenseCategory[]
  projects            Project[]
  emailTemplates      EmailTemplate[]
  attachments         Attachment[]
  clientNotes         ClientNote[]
  projectNotes        ProjectNote[]
  profileEnquiries    PublicProfileEnquiry[]
  tasks               Task[]
  taskBoards          TaskBoard[]
  threads             Thread[]

  @@map("workspaces")
}

model WorkspaceRole {
  id          String                    @id @default(cuid())
  key         String                    @unique
  name        String
  description String?
  isSystem    Boolean                   @default(true)
  sortOrder   Int                       @default(0)
  permissions WorkspaceRolePermission[]
  members     WorkspaceMember[]
  createdAt   DateTime                  @default(now())

  @@map("workspace_roles")
}

model WorkspaceRolePermission {
  id         String        @id @default(cuid())
  roleId     String
  role       WorkspaceRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission

  @@unique([roleId, permission])
  @@index([roleId])
  @@map("workspace_role_permissions")
}

model WorkspaceMember {
  id              String           @id @default(cuid())
  userId          String
  workspaceId     String
  role            LegacyMemberRole @default(MEMBER)
  workspaceRoleId String
  workspaceRole   WorkspaceRole    @relation(fields: [workspaceRoleId], references: [id])
  joinedAt        DateTime         @default(now())

  user      User      @relation(fields: [userId],      references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

model User {
  id                      String           @id
  email                   String           @unique
  name                    String
  plan                    Plan             @default(FREE)
  planExpiresAt           DateTime?
  cashfreeSubscriptionId  String?
  cashfreePlanId          String?
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  subscriptionStatus      SubscriptionStatus @default(NONE)
  billingAnchorDate       DateTime?
  businessName            String?
  logoUrl                 String?
  gstNumber               String?
  panNumber               String?
  businessType            String?
  razorpayAccountId       String?
  bankName                String?
  bankAccountName         String?
  bankAccountNumber       String?
  bankIfsc                String?
  upiId                   String?
  upiQrUrl                String?
  country                 String?
  currency                String?
  taxLabel                String?
  ibanNumber              String?
  swiftCode               String?
  routingNumber           String?
  defaultHsnSac           String?
  defaultLutNumber        String?
  onboardingComplete      Boolean  @default(false)
  razorpayKeyId           String?
  razorpayKeySecret       String?
  googleAccessToken         String?
  googleRefreshToken        String?
  googleTokenExpiresAt      DateTime?
  googleCalendarConnected   Boolean          @default(false)
  googleDocsConnected       Boolean          @default(false)
  googleFormsConnected      Boolean          @default(false)
  googleFormsWebhookToken   String?          @unique
  googleSheetsConnected     Boolean          @default(false)
  googleSheetsId            String?
  outlookAccessToken      String?
  outlookRefreshToken     String?
  outlookTokenExpiresAt   DateTime?
  outlookConnected        Boolean          @default(false)
  clickUpAccessToken      String?
  clickUpConnected        Boolean          @default(false)
  clickUpWorkspaceId      String?
  flodeskApiKey           String?
  flodeskConnected        Boolean          @default(false)
  canvaAccessToken        String?
  canvaRefreshToken       String?
  canvaTokenExpiresAt     DateTime?
  canvaConnected          Boolean          @default(false)
  canvaPkceState          String?
  canvaPkceVerifier       String?
  canvaPkceExpiresAt      DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  // Public Profile
  publicUsername          String?          @unique
  publicProfileEnabled    Boolean          @default(false)
  publicUsernameChanged   Boolean          @default(false)
  publicBio               String?
  publicCity              String?
  publicWhatsapp          String?
  publicLanguages         String[]         @default([])
  publicSkills            String[]         @default([])
  publicServices          Json             @default("[]")
  publicPortfolio         Json             @default("[]")
  publicAccentColor       String           @default("indigo")
  // Cached stats (recalculated nightly)
  statsProjectsCompleted  Int              @default(0)
  statsTotalEarned        Decimal          @default(0) @db.Decimal(14, 2)
  statsRepeatClientPct    Int              @default(0)
  statsAcceptanceRate     Int              @default(0)
  statsAvgResponseHrs     Int              @default(0)
  statsLastCalculatedAt   DateTime?
  // Team
  ownerId                  String?
  owner                    User?             @relation("TeamMembers", fields: [ownerId], references: [id])
  teamMembers              User[]            @relation("TeamMembers")
  teamInvitesSent          TeamInvite[]
  // Workspace
  activeWorkspaceId        String?
  activeWorkspace          Workspace?        @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  workspaceMemberships     WorkspaceMember[]

  assignedTasks           Task[]       @relation("TaskAssignee")
  emailSignature          String?

  @@map("users")
}

model PromoCode {
  id             String            @id @default(cuid())
  code           String            @unique
  plan           Plan
  discountType   DiscountType      @default(FULL_ACCESS)
  durationMonths Int?
  maxRedemptions Int?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  redemptions    PromoRedemption[]

  @@map("promo_codes")
}

model BillingConfig {
  id                    String   @id @default("singleton")
  foundingPeriodEnds    DateTime
  earlyAccessPeriodEnds DateTime

  @@map("billing_configs")
}

model BillingEvent {
  id          String   @id @default(cuid())
  eventType   String
  cashfreeRef String   @unique
  workspaceId String?
  payload     Json
  processedAt DateTime @default(now())

  @@map("billing_events")
}

model PromoRedemption {
  id          String    @id @default(cuid())
  codeId      String
  code        PromoCode @relation(fields: [codeId], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  redeemedAt  DateTime  @default(now())

  @@unique([codeId, workspaceId])
  @@map("promo_redemptions")
}

model IntakeForm {
  id          String                 @id @default(cuid())
  workspaceId String
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  description String?
  token       String                 @unique
  fields         Json
  isActive       Boolean                @default(true)
  autoCreateLead Boolean                @default(false)
  leadFieldMap   Json                   @default("{}")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  archivedAt     DateTime?
  submissions    IntakeFormSubmission[]

  @@map("intake_forms")
}

model IntakeFormSubmission {
  id              String     @id @default(cuid())
  formId          String
  form            IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  respondentEmail String?
  respondentName  String?
  answers         Json
  submittedAt     DateTime   @default(now())

  @@map("intake_form_submissions")
}

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  entityId   String?
  entityType String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("notifications")
}

model PushSubscription {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("push_subscriptions")
}

model Client {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  company     String?
  gstNumber   String?
  state       String?
  portalToken     String?    @unique
  clickupMemberId String?    @unique
  createdAt       DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  archivedAt  DateTime?
  leads       Lead[]
  proposals   Proposal[]
  contracts   Contract[]
  invoices    Invoice[]
  meetings    Meeting[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  projects    Project[]
  attachments Attachment[]
  notes       ClientNote[]
  threads     Thread[]

  @@index([workspaceId])
  @@index([workspaceId, archivedAt])
  @@map("clients")
}

model Lead {
  id             String     @id @default(cuid())
  workspaceId    String
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?    @relation(fields: [clientId], references: [id])
  name           String
  email          String?
  phone          String?
  company        String?
  service        String?
  budget         Decimal?   @db.Decimal(12, 2)
  source         String?
  stage          LeadStage  @default(ENQUIRY)
  notes          String?
  lastActivityAt DateTime   @default(now())
  followUpAt     DateTime?
  isDeleted      Boolean    @default(false)
  archivedAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  proposals      Proposal[]
  meetings       Meeting[]

  @@index([workspaceId])
  @@index([workspaceId, archivedAt, stage])
  @@index([workspaceId, followUpAt])
  @@index([clientId])
  @@map("leads")
}

enum LeadStage {
  ENQUIRY
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
}

model Proposal {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?          @relation(fields: [leadId], references: [id])
  clientId    String?
  client      Client?        @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id])
  title       String
  status      ProposalStatus @default(DRAFT)
  slug        String         @unique
  content     Json
  totalAmount Decimal        @db.Decimal(12, 2)
  gstAmount   Decimal        @default(0) @db.Decimal(12, 2)
  hidePricingTable Boolean   @default(false)
  validUntil      DateTime?
  acceptedAt      DateTime?
  depositOrderId  String?
  depositAmount   Decimal?       @db.Decimal(12, 2)
  depositPaid     Boolean        @default(false)
  depositPaidAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  archivedAt      DateTime?
  opens           ProposalOpen[]
  contracts       Contract[]
  attachments     Attachment[]

  @@index([workspaceId, status])
  @@index([workspaceId, archivedAt])
  @@index([clientId])
  @@index([projectId])
  @@index([leadId])
  @@map("proposals")
}

enum ProposalStatus {
  DRAFT
  SENT
  OPENED
  ACCEPTED
  DECLINED
  EXPIRED
}

model ProposalOpen {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  pagesViewed Json?
  openedAt    DateTime @default(now())

  @@index([proposalId])
  @@map("proposal_opens")
}

model Contract {
  id         String         @id @default(cuid())
  workspaceId String
  workspace  Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  proposalId String?
  proposal   Proposal?      @relation(fields: [proposalId], references: [id])
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project?       @relation(fields: [projectId], references: [id])
  title      String
  status     ContractStatus @default(DRAFT)
  content    Json
  sentAt     DateTime?
  signedAt   DateTime?
  signerOtp  String?
  auditLog   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  archivedAt DateTime?
  invoices   Invoice[]

  @@index([workspaceId, status])
  @@index([workspaceId, archivedAt])
  @@index([clientId])
  @@index([projectId])
  @@index([proposalId])
  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
  VOID
}

model Invoice {
  id                String        @id @default(cuid())
  workspaceId       String
  workspace         Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contractId        String?
  contract          Contract?     @relation(fields: [contractId], references: [id])
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id])
  projectId         String?
  project           Project?      @relation(fields: [projectId], references: [id])
  invoiceNumber     String        @unique
  status            InvoiceStatus @default(DRAFT)
  lineItems         Json
  subtotal          Decimal       @db.Decimal(12, 2)
  gstAmount         Decimal       @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  gstType           GstType       @default(IGST)
  tdsRate           Decimal?      @db.Decimal(5, 2)
  currency          String        @default("INR")
  exchangeRate      Decimal?  @db.Decimal(10, 6)
  lutNumber         String?
  tdsDeducted       Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(12, 2)
  dueDate           DateTime?
  paidAt            DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  remindersSent      Int           @default(0)
  isRecurring        Boolean       @default(false)
  recurrenceCycle    String?
  recurrenceDay      Int?
  recurrenceEndDate  DateTime?
  recurrenceNextDate DateTime?
  parentInvoiceId    String?
  parentInvoice      Invoice?      @relation("InvoiceRecurrence", fields: [parentInvoiceId], references: [id])
  childInvoices      Invoice[]     @relation("InvoiceRecurrence")
  attachments        Attachment[]  @relation("InvoiceAttachments")
  gatedAttachments   Attachment[]  @relation("InvoiceGate")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@index([clientId])
  @@index([projectId])
  @@index([contractId])
  @@index([parentInvoiceId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum GstType {
  CGST_SGST
  IGST
  EXEMPT
}

model AutomationRule {
  id          String                @id @default(cuid())
  workspaceId String
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key           String
  name          String
  description   String?
  category      String
  triggerEvent  String
  triggerConfig Json                  @default("{}")
  actionType    String
  actionConfig  Json                  @default("{}")
  isActive      Boolean               @default(true)
  isSystem      Boolean               @default(true)
  lastRunAt     DateTime?
  runCount      Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  executions    AutomationExecution[]

  @@unique([workspaceId, key])
  @@map("automation_rules")
}

model AutomationExecution {
  id         String          @id @default(cuid())
  ruleId     String
  rule       AutomationRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  entityId   String?
  entityType String?
  status     ExecutionStatus @default(SUCCESS)
  error      String?
  metadata   Json?
  firedAt    DateTime        @default(now())

  @@index([ruleId])
  @@map("automation_executions")
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model EmailLog {
  id          String   @id @default(cuid())
  workspaceId String
  to          String
  subject     String
  templateKey String
  entityId    String?
  entityType  String?
  status      String
  error       String?
  sentAt      DateTime @default(now())

  @@map("email_logs")
}

model Meeting {
  id            String        @id @default(cuid())
  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?         @relation(fields: [leadId], references: [id])
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  title         String
  agenda        String?
  scheduledAt   DateTime
  durationMins  Int           @default(30)
  meetLink       String?
  googleEventId  String?
  outlookEventId String?
  meetProvider   String?
  status         MeetingStatus @default(SCHEDULED)
  reminderSent  Boolean       @default(false)
  guestEmails   String[]      @default([])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([workspaceId, clientId])
  @@index([workspaceId, scheduledAt])
  @@index([leadId])
  @@map("meetings")
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model ProposalTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String?
  content     Json
  totalAmount Decimal   @default(0) @db.Decimal(12, 2)
  usageCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@map("proposal_templates")
}

model AutomationWorkflow {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean       @default(false)
  trigger     Json          @default("{}")
  steps       Json          @default("[]")
  runCount    Int           @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  runs        WorkflowRun[]

  @@map("automation_workflows")
}

model WorkflowRun {
  id           String            @id @default(cuid())
  workflowId   String
  workflow     AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workspaceId  String
  entityId     String
  entityType   String
  status       WorkflowRunStatus @default(RUNNING)
  pendingSteps Json              @default("[]")
  log          Json              @default("[]")
  nextFireAt   DateTime
  startedAt    DateTime          @default(now())
  completedAt  DateTime?

  @@index([status, nextFireAt])
  @@map("workflow_runs")
}

enum WorkflowRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model TimeEntry {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id])
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  description  String
  date         DateTime
  durationMins Int
  hourlyRate   Decimal?  @db.Decimal(10, 2)
  isBilled      Boolean  @default(false)
  invoiceId     String?
  clickupTaskId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([projectId])
  @@index([clientId])
  @@map("time_entries")
}

model Expense {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  category    String
  description String
  amount      Decimal   @db.Decimal(12, 2)
  date        DateTime
  receiptUrl  String?
  isBillable  Boolean   @default(true)
  isBilled    Boolean   @default(false)
  invoiceId   String?
  vendor      String?
  gstRate     Decimal?  @db.Decimal(5, 2)
  gstAmount   Decimal?  @db.Decimal(12, 2)
  tdsSection  String?
  tdsRate     Decimal?  @db.Decimal(5, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([projectId])
  @@index([clientId])
  @@map("expenses")
}

model UserExpenseCategory {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String

  @@unique([workspaceId, name])
  @@map("user_expense_categories")
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  name        String
  description String?
  status               ProjectStatus @default(ACTIVE)
  budget               Decimal?      @db.Decimal(12, 2)
  startDate            DateTime?
  endDate              DateTime?
  shareRateWithClient  Boolean       @default(false)
  clickupListId        String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?
  proposals   Proposal[]
  contracts   Contract[]
  invoices    Invoice[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  attachments Attachment[]
  notes       ProjectNote[]
  tasks       Task[]
  taskBoards  TaskBoard[]

  @@index([workspaceId, status])
  @@index([workspaceId, archivedAt])
  @@index([clientId])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum TaskStatus {
  TODO
  COMPLETED
}

model Task {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  includeTime Boolean      @default(false)
  isPrivate   Boolean      @default(false)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  columnId    String?
  column      BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  position    Int          @default(0)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([workspaceId])
  @@index([projectId])
  @@index([columnId])
  @@index([assigneeId])
  @@map("tasks")
}

model TaskBoard {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  position    Int           @default(0)
  columns     BoardColumn[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?

  @@index([workspaceId])
  @@index([projectId])
  @@map("task_boards")
}

model BoardColumn {
  id       String    @id @default(cuid())
  boardId  String
  board    TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name     String
  position Int       @default(0)
  isDone   Boolean   @default(false)
  color    String?
  tasks    Task[]

  @@index([boardId])
  @@map("board_columns")
}

model EmailTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  templateKey String
  subject     String
  bodyHtml    String    @db.Text
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, templateKey])
  @@map("email_templates")
}

model ClientNote {
  id          String    @id @default(cuid())
  workspaceId String
  clientId    String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId],    references: [id], onDelete: Cascade)

  @@index([workspaceId, clientId])
  @@map("client_notes")
}

model ProjectNote {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId],   references: [id], onDelete: Cascade)

  @@index([workspaceId, projectId])
  @@map("project_notes")
}

model Attachment {
  id          String   @id @default(cuid())
  workspaceId String

  // Polymorphic parent — exactly one of these should be set
  projectId  String?
  proposalId String?
  invoiceId  String?
  clientId   String?

  // Optional payment gate — null = freely downloadable
  gateInvoiceId String?

  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId],  references: [id], onDelete: Cascade)
  proposal    Proposal? @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  invoice     Invoice?  @relation("InvoiceAttachments", fields: [invoiceId],     references: [id], onDelete: Cascade)
  client      Client?   @relation(fields: [clientId],   references: [id], onDelete: Cascade)
  gateInvoice Invoice?  @relation("InvoiceGate",        fields: [gateInvoiceId], references: [id])

  @@index([workspaceId])
  @@index([clientId])
  @@index([projectId])
  @@index([invoiceId])
  @@index([proposalId])
  @@map("attachments")
}

model TeamInvite {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  email           String
  token           String   @unique
  accepted        Boolean  @default(false)
  expiresAt       DateTime
  workspaceRoleId String?
  createdAt       DateTime @default(now())

  @@unique([ownerId, email])
  @@map("team_invites")
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_signups")
}

model PublicProfileEnquiry {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  senderName    String
  senderPhone   String?
  senderEmail   String?
  budget        String?
  serviceNeeded String?
  brief         String?
  createdAt     DateTime @default(now())

  @@map("public_profile_enquiries")
}

// ── Messaging ──────────────────────────────────────────────────────────────────

enum SenderType {
  FREELANCER
  CLIENT
}

enum AttachmentType {
  PROPOSAL
  INVOICE
  CONTRACT
}

model Thread {
  id          String    @id @default(cuid())
  workspaceId String
  clientId    String
  subject     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId],    references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([workspaceId, clientId])
  @@map("threads")
}

model Message {
  id             String          @id @default(cuid())
  threadId       String
  senderType     SenderType
  body           String
  attachmentType AttachmentType?
  attachmentId   String?
  readAt         DateTime?
  createdAt      DateTime        @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("messages")
}
