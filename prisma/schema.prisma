generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  SOLO
  STUDIO
}

model User {
  id                      String           @id
  email                   String           @unique
  name                    String
  plan                    Plan             @default(FREE)
  planExpiresAt           DateTime?
  businessName            String?
  logoUrl                 String?
  gstNumber               String?
  panNumber               String?
  businessType            String?
  razorpayAccountId       String?
  bankName                String?
  bankAccountName         String?
  bankAccountNumber       String?
  bankIfsc                String?
  upiId                   String?
  googleAccessToken       String?
  googleRefreshToken      String?
  googleTokenExpiresAt    DateTime?
  googleCalendarConnected Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  leads                   Lead[]
  clients                 Client[]
  proposals               Proposal[]
  contracts               Contract[]
  invoices                Invoice[]
  automationRules         AutomationRule[]
  automationWorkflows     AutomationWorkflow[]
  notifications           Notification[]
  meetings                Meeting[]
  proposalTemplates       ProposalTemplate[]
  promoRedemptions        PromoRedemption[]
  intakeForms             IntakeForm[]
  timeEntries             TimeEntry[]
  expenses                Expense[]
  projects                Project[]

  @@map("users")
}

model PromoCode {
  id          String            @id @default(cuid())
  code        String            @unique
  plan        Plan
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  redemptions PromoRedemption[]

  @@map("promo_codes")
}

model PromoRedemption {
  id         String    @id @default(cuid())
  codeId     String
  code       PromoCode @relation(fields: [codeId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  redeemedAt DateTime  @default(now())

  @@unique([codeId, userId])
  @@map("promo_redemptions")
}

model IntakeForm {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  token       String                 @unique
  fields      Json
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions IntakeFormSubmission[]

  @@map("intake_forms")
}

model IntakeFormSubmission {
  id              String     @id @default(cuid())
  formId          String
  form            IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  respondentEmail String?
  respondentName  String?
  answers         Json
  submittedAt     DateTime   @default(now())

  @@map("intake_form_submissions")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  entityId   String?
  entityType String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("notifications")
}

model Client {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  company     String?
  gstNumber   String?
  state       String?
  portalToken String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  leads       Lead[]
  proposals   Proposal[]
  contracts   Contract[]
  invoices    Invoice[]
  meetings    Meeting[]
  timeEntries TimeEntry[]
  expenses    Expense[]
  projects    Project[]

  @@map("clients")
}

model Lead {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?    @relation(fields: [clientId], references: [id])
  name           String
  email          String?
  phone          String?
  company        String?
  service        String?
  budget         Decimal?   @db.Decimal(12, 2)
  source         String?
  stage          LeadStage  @default(ENQUIRY)
  notes          String?
  lastActivityAt DateTime   @default(now())
  followUpAt     DateTime?
  isDeleted      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  proposals      Proposal[]
  meetings       Meeting[]

  @@map("leads")
}

enum LeadStage {
  ENQUIRY
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?          @relation(fields: [leadId], references: [id])
  clientId    String?
  client      Client?        @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id])
  title       String
  status      ProposalStatus @default(DRAFT)
  slug        String         @unique
  content     Json
  totalAmount Decimal        @db.Decimal(12, 2)
  gstAmount   Decimal        @default(0) @db.Decimal(12, 2)
  validUntil      DateTime?
  acceptedAt      DateTime?
  depositOrderId  String?
  depositAmount   Decimal?       @db.Decimal(12, 2)
  depositPaid     Boolean        @default(false)
  depositPaidAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  opens           ProposalOpen[]
  contracts       Contract[]

  @@map("proposals")
}

enum ProposalStatus {
  DRAFT
  SENT
  OPENED
  ACCEPTED
  DECLINED
  EXPIRED
}

model ProposalOpen {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  pagesViewed Json?
  openedAt    DateTime @default(now())

  @@map("proposal_opens")
}

model Contract {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposalId String?
  proposal   Proposal?      @relation(fields: [proposalId], references: [id])
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project?       @relation(fields: [projectId], references: [id])
  title      String
  status     ContractStatus @default(DRAFT)
  content    Json
  sentAt     DateTime?
  signedAt   DateTime?
  signerOtp  String?
  auditLog   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  invoices   Invoice[]

  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
}

model Invoice {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractId        String?
  contract          Contract?     @relation(fields: [contractId], references: [id])
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id])
  projectId         String?
  project           Project?      @relation(fields: [projectId], references: [id])
  invoiceNumber     String        @unique
  status            InvoiceStatus @default(DRAFT)
  lineItems         Json
  subtotal          Decimal       @db.Decimal(12, 2)
  gstAmount         Decimal       @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  gstType           GstType       @default(IGST)
  tdsRate           Decimal?      @db.Decimal(5, 2)
  amountPaid        Decimal       @default(0) @db.Decimal(12, 2)
  dueDate           DateTime?
  paidAt            DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  remindersSent      Int           @default(0)
  isRecurring        Boolean       @default(false)
  recurrenceCycle    String?
  recurrenceDay      Int?
  recurrenceEndDate  DateTime?
  recurrenceNextDate DateTime?
  parentInvoiceId    String?
  parentInvoice      Invoice?      @relation("InvoiceRecurrence", fields: [parentInvoiceId], references: [id])
  childInvoices      Invoice[]     @relation("InvoiceRecurrence")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum GstType {
  CGST_SGST
  IGST
  EXEMPT
}

model AutomationRule {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  key           String
  name          String
  description   String?
  category      String
  triggerEvent  String
  triggerConfig Json                  @default("{}")
  actionType    String
  actionConfig  Json                  @default("{}")
  isActive      Boolean               @default(true)
  isSystem      Boolean               @default(true)
  lastRunAt     DateTime?
  runCount      Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  executions    AutomationExecution[]

  @@unique([userId, key])
  @@map("automation_rules")
}

model AutomationExecution {
  id         String          @id @default(cuid())
  ruleId     String
  rule       AutomationRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  entityId   String?
  entityType String?
  status     ExecutionStatus @default(SUCCESS)
  error      String?
  metadata   Json?
  firedAt    DateTime        @default(now())

  @@map("automation_executions")
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model EmailLog {
  id          String   @id @default(cuid())
  userId      String
  to          String
  subject     String
  templateKey String
  entityId    String?
  entityType  String?
  status      String
  error       String?
  sentAt      DateTime @default(now())

  @@map("email_logs")
}

model Meeting {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId        String?
  lead          Lead?         @relation(fields: [leadId], references: [id])
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  title         String
  agenda        String?
  scheduledAt   DateTime
  durationMins  Int           @default(30)
  meetLink      String?
  googleEventId String?
  status        MeetingStatus @default(SCHEDULED)
  reminderSent  Boolean       @default(false)
  guestEmails   String[]      @default([])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("meetings")
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model ProposalTemplate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  category    String?
  content     Json
  totalAmount Decimal  @default(0) @db.Decimal(12, 2)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("proposal_templates")
}

model AutomationWorkflow {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean      @default(false)
  trigger     Json         @default("{}")
  steps       Json         @default("[]")
  runCount    Int          @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  runs        WorkflowRun[]

  @@map("automation_workflows")
}

model WorkflowRun {
  id           String            @id @default(cuid())
  workflowId   String
  workflow     AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId       String
  entityId     String
  entityType   String
  status       WorkflowRunStatus @default(RUNNING)
  pendingSteps Json              @default("[]")
  log          Json              @default("[]")
  nextFireAt   DateTime
  startedAt    DateTime          @default(now())
  completedAt  DateTime?

  @@index([status, nextFireAt])
  @@map("workflow_runs")
}

enum WorkflowRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model TimeEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  description  String
  date         DateTime
  durationMins Int
  hourlyRate   Decimal? @db.Decimal(10, 2)
  isBilled     Boolean  @default(false)
  invoiceId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("time_entries")
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  receiptUrl  String?
  isBillable  Boolean  @default(true)
  isBilled    Boolean  @default(false)
  invoiceId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  budget      Decimal?      @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  proposals   Proposal[]
  contracts   Contract[]
  invoices    Invoice[]
  timeEntries TimeEntry[]
  expenses    Expense[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}
